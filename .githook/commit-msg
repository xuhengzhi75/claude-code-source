#!/usr/bin/env bash
# =============================================================================
# commit-msg 安全检查 — claude-code-source
#
# 检查提交信息是否包含公司名/内部信息/敏感关键字
# 用法：由 git 自动调用，参数 $1 为 commit message 临时文件路径
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
NC='\033[0m'

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

FAIL=0
ERRORS=()
WARNINGS=()

# =============================================================================
# 检测函数
# =============================================================================

check_msg_pattern() {
  local category="$1"
  local pattern="$2"
  local description="$3"
  local severity="${4:-ERROR}"

  if echo "$COMMIT_MSG" | grep -qiP "$pattern" 2>/dev/null; then
    if [ "$severity" = "WARN" ]; then
      WARNINGS+=("[$category] $description")
    else
      ERRORS+=("[$category] $description")
      FAIL=1
    fi
  fi
}

# =============================================================================
# 1. 公司名 / 内部标识
# =============================================================================

check_msg_pattern "INTERNAL" \
  '\bsankuai\b' \
  "提交信息包含 sankuai（内部组织标识）"

check_msg_pattern "INTERNAL" \
  '\bdianping\b' \
  "提交信息包含 dianping（内部品牌）"

# catXXX 产品代号（catdesk/catpaw 等）
check_msg_pattern "INTERNAL" \
  '\bcat(desk|paw|code|eye|brain|flow|lab|hub|bot|ai)\b' \
  "提交信息包含内部产品代号（catXXX）" "WARN"

# 内部工具名
check_msg_pattern "INTERNAL" \
  '\b(friday|growthbook|statsig|tengu|openclaw)\b' \
  "提交信息包含内部工具名" "WARN"

# =============================================================================
# 2. 内部 URL
# =============================================================================

check_msg_pattern "INTERNAL_URL" \
  'sankuai\.com' \
  "提交信息包含 sankuai.com 内网域名"

check_msg_pattern "INTERNAL_URL" \
  'km\.sankuai\.com' \
  "提交信息包含学城链接"

# =============================================================================
# 3. 敏感信息
# =============================================================================

check_msg_pattern "SECRET" \
  '(api[_-]?key|token|secret|password|passwd)\s*[:=]\s*\S{8,}' \
  "提交信息疑似包含密钥/密码赋值"

check_msg_pattern "PII" \
  '[a-zA-Z0-9._%+\-]+@(meituan|sankuai|dianping)\.com' \
  "提交信息包含内部邮箱"

check_msg_pattern "PII" \
  '(?<!\d)1[3-9][0-9]{9}(?!\d)' \
  "提交信息包含疑似手机号"

# =============================================================================
# 4. 私有规则（从 .git/hooks/private-rules-msg.txt 加载）
# =============================================================================
PRIVATE_MSG_RULES="$(git rev-parse --git-dir)/hooks/private-rules-msg.txt"
if [ -f "$PRIVATE_MSG_RULES" ]; then
  while IFS='|' read -r category pattern description severity || [ -n "$category" ]; do
    [[ -z "$category" || "$category" == \#* ]] && continue
    severity="${severity:-ERROR}"
    check_msg_pattern "$category" "$pattern" "$description" "$severity"
  done < "$PRIVATE_MSG_RULES"
fi

# =============================================================================
# 5. 结果输出
# =============================================================================

if [ ${#ERRORS[@]} -eq 0 ] && [ ${#WARNINGS[@]} -eq 0 ]; then
  exit 0
fi

echo ""
echo "================================================"
echo "  🔒 Commit Message Security Check"
echo "================================================"

if [ ${#ERRORS[@]} -gt 0 ]; then
  echo -e "${RED}❌ 提交信息包含敏感内容（BLOCK）：${NC}"
  for err in "${ERRORS[@]}"; do
    echo -e "  ${RED}✗ $err${NC}"
  done
  echo ""
fi

if [ ${#WARNINGS[@]} -gt 0 ]; then
  echo -e "${YELLOW}⚠️  提交信息包含疑似内部信息（请确认）：${NC}"
  for warn in "${WARNINGS[@]}"; do
    echo -e "  ${YELLOW}! $warn${NC}"
  done
  echo ""
fi

if [ $FAIL -eq 1 ]; then
  echo -e "${RED}提交已阻止。请修改提交信息后重新提交。${NC}"
  echo "跳过此检查（慎用）: git commit --no-verify"
  echo "================================================"
  echo ""
  exit 1
fi

echo "================================================"
echo ""
exit 0
