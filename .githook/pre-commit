#!/usr/bin/env bash
# =============================================================================
# pre-commit 安全检查 — claude-code-source
#
# 策略：
#   - 首次提交 / 距上次提交超过 1 天：全仓库扫描
#   - 其余情况：仅扫描 staged 内容
#
# 跳过（慎用）：git commit --no-verify
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

VERBOSE="${VERBOSE:-0}"
FAIL=0
WARNINGS=()
ERRORS=()

REPO_ROOT="$(git rev-parse --show-toplevel)"
TIMESTAMP_FILE="$(git rev-parse --git-dir)/hooks/.last-full-scan"

# =============================================================================
# 判断扫描模式：full（全仓库）或 incremental（仅 staged）
# =============================================================================
SCAN_MODE="incremental"

last_commit_time=$(git log -1 --format="%ct" 2>/dev/null || echo "0")
now=$(date +%s)
elapsed=$(( now - last_commit_time ))

if [ "$last_commit_time" = "0" ] || [ "$elapsed" -gt 86400 ]; then
  SCAN_MODE="full"
fi

# 也可通过环境变量强制全量
[ "${FORCE_FULL_SCAN:-0}" = "1" ] && SCAN_MODE="full"

if [ "$VERBOSE" = "1" ]; then
  echo -e "${CYAN}[安全检查] 扫描模式：$SCAN_MODE${NC}"
fi

# =============================================================================
# 获取扫描目标
# =============================================================================

# staged diff（豁免 .githook/ 自身，防止规则字符串触发自检）
_RAW_DIFF=$(git diff --cached --unified=0 2>/dev/null || true)
STAGED_DIFF=$(echo "$_RAW_DIFF" | awk '
  /\.githook\// && /^diff --git/ { skip=1; next }
  /^diff --git/ && !/.githook\// { skip=0 }
  skip { next }
  { print }
')
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null | grep -v '^\.githook/' || true)

if [ -z "$STAGED_DIFF" ] && [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}✅ 安全检查通过（无待扫描内容）${NC}"
  exit 0
fi

# =============================================================================
# 私有敏感词文件（不入仓库，存放在 .git/hooks/）
# =============================================================================
PRIVATE_RULES_FILE="$(git rev-parse --git-dir)/hooks/private-rules.txt"

# =============================================================================
# 检测函数
# =============================================================================

check_pattern() {
  local category="$1"
  local pattern="$2"
  local description="$3"
  local severity="${4:-ERROR}"
  local target="${5:-staged}"   # staged | full

  local content="$STAGED_DIFF"
  if [ "$target" = "full" ] && [ "$SCAN_MODE" = "full" ]; then
    # 全仓库扫描时用 git ls-files 内容
    content=$(git ls-files -z | xargs -0 cat 2>/dev/null || true)
  fi

  if echo "$content" | grep -qP "$pattern" 2>/dev/null; then
    if [ "$severity" = "WARN" ]; then
      WARNINGS+=("[$category] $description")
    else
      ERRORS+=("[$category] $description")
      FAIL=1
    fi
  fi
}

check_file_pattern() {
  local category="$1"
  local pattern="$2"
  local description="$3"
  local severity="${4:-ERROR}"

  local files_to_check="$STAGED_FILES"
  if [ "$SCAN_MODE" = "full" ]; then
    files_to_check=$(git ls-files 2>/dev/null || true)
  fi

  if echo "$files_to_check" | grep -qP "$pattern" 2>/dev/null; then
    local matched
    matched=$(echo "$files_to_check" | grep -P "$pattern" | head -3)
    if [ "$severity" = "WARN" ]; then
      WARNINGS+=("[$category] $description: $matched")
    else
      ERRORS+=("[$category] $description: $matched")
      FAIL=1
    fi
  fi
}

# =============================================================================
# 1. API Keys / Tokens / Secrets
# =============================================================================

check_pattern "SECRET" \
  '(?i)(api[_-]?key|apikey|api[_-]?secret)\s*[:=]\s*["\x27]?[A-Za-z0-9_\-]{16,}' \
  "疑似 API Key 赋值"

check_pattern "SECRET" \
  '(?i)(secret[_-]?key|secret[_-]?token|app[_-]?secret)\s*[:=]\s*["\x27]?[A-Za-z0-9_\-]{16,}' \
  "疑似 Secret Key/Token 赋值"

check_pattern "GITHUB" \
  'ghp_[A-Za-z0-9]{36}' \
  "GitHub Personal Access Token (ghp_...)"

check_pattern "GITHUB" \
  'ghs_[A-Za-z0-9]{36}' \
  "GitHub Service Account Token (ghs_...)"

check_pattern "GITHUB" \
  'gho_[A-Za-z0-9]{36}' \
  "GitHub OAuth Token (gho_...)"

check_pattern "GITHUB" \
  'github_pat_[A-Za-z0-9_]{82}' \
  "GitHub Fine-grained PAT"

check_pattern "OPENAI" \
  'sk-[A-Za-z0-9]{20,}' \
  "疑似 OpenAI / OpenAI-compatible API Key (sk-...)"

check_pattern "AWS" \
  'AKIA[0-9A-Z]{16}' \
  "AWS Access Key ID"

check_pattern "AWS" \
  '(?i)aws[_-]?secret[_-]?access[_-]?key\s*[:=]\s*[A-Za-z0-9/+=]{40}' \
  "AWS Secret Access Key"

check_pattern "TOKEN" \
  '(?i)bearer\s+[A-Za-z0-9\-._~+/]+=*' \
  "Bearer Token 明文"

check_pattern "TOKEN" \
  '(?i)(access[_-]?token|auth[_-]?token|oauth[_-]?token)\s*[:=]\s*["\x27]?[A-Za-z0-9_\-\.]{16,}' \
  "疑似 Access/Auth Token 赋值"

check_pattern "JWT" \
  'eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}' \
  "JWT Token 明文"

check_pattern "PRIVKEY" \
  '-----BEGIN (RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY( BLOCK)?-----' \
  "PEM 私钥"

check_pattern "PRIVKEY" \
  '-----BEGIN CERTIFICATE-----' \
  "PEM 证书（可能含私钥链）" "WARN"

check_pattern "PASSWORD" \
  '(?i)(password|passwd|pwd)\s*[:=]\s*["\x27][^"\x27\s]{6,}["\x27]' \
  "疑似明文密码赋值"

check_pattern "ENTROPY" \
  '"[A-Za-z0-9+/]{40,}={0,2}"' \
  "疑似高熵 Base64 字符串（可能是 token/key）" "WARN"

# =============================================================================
# 2. 内部人员信息
# =============================================================================

# 真实姓名（从本地私有文件读取，不入仓库）
BLOCKED_NAMES_FILE="$(git rev-parse --git-dir)/hooks/blocked-names.txt"
if [ -f "$BLOCKED_NAMES_FILE" ]; then
  while IFS= read -r name || [ -n "$name" ]; do
    [[ -z "$name" || "$name" == \#* ]] && continue
    if echo "$STAGED_DIFF" | grep -qF "$name" 2>/dev/null; then
      ERRORS+=("[PII] 真实姓名出现在提交内容中（见 .git/hooks/blocked-names.txt）")
      FAIL=1
      break
    fi
  done < "$BLOCKED_NAMES_FILE"
fi

check_pattern "INTERNAL" \
  '(?i)(misid|mis_id|mis-id)\s*[:=]\s*["\x27]?[a-z0-9]{6,}' \
  "疑似美团 misId 赋值"

check_pattern "INTERNAL" \
  '(?i)(uid|user[_-]?id|employee[_-]?id)\s*[:=]\s*["\x27]?[0-9]{8,12}["\x27]?' \
  "疑似员工 UID 赋值" "WARN"

check_pattern "PII" \
  '(?<!\d)1[3-9][0-9]{9}(?!\d)' \
  "疑似中国大陆手机号"

check_pattern "PII" \
  '[a-zA-Z0-9._%+\-]+@(meituan|sankuai|dianping)\.com' \
  "美团/美团点评内部邮箱"

check_pattern "PII" \
  '(?<!\d)[1-9][0-9]{16}[0-9Xx](?!\d)' \
  "疑似中国居民身份证号" "WARN"

# =============================================================================
# 3. 内部 URL / 系统地址
# =============================================================================

check_pattern "INTERNAL_URL" \
  'https?://[a-zA-Z0-9\-\.]*\.sankuai\.com' \
  "美团内网 sankuai.com 域名链接"

check_pattern "INTERNAL_URL" \
  'https?://[a-zA-Z0-9\-\.]*\.meituan\.(com|net)/[a-zA-Z0-9/\-_?=&]+' \
  "疑似美团内部 meituan.com 路径链接" "WARN"

check_pattern "INTERNAL_URL" \
  'https?://km\.sankuai\.com' \
  "学城 km.sankuai.com 链接"

check_pattern "INTERNAL_URL" \
  'https?://ones\.sankuai\.com' \
  "ONES 内部链接"

check_pattern "INTERNAL_URL" \
  'https?://bi\.sankuai\.com' \
  "魔数 BI 内部链接"

check_pattern "INTERNAL_URL" \
  'localhost:[0-9]{4,5}' \
  "localhost 端口引用（可能是内部服务）" "WARN"

check_pattern "INTERNAL_URL" \
  '192\.168\.[0-9]{1,3}\.[0-9]{1,3}' \
  "内网 IP 地址 (192.168.x.x)" "WARN"

check_pattern "INTERNAL_URL" \
  '10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}' \
  "内网 IP 地址 (10.x.x.x)" "WARN"

check_pattern "INTERNAL_URL" \
  '172\.(1[6-9]|2[0-9]|3[01])\.[0-9]{1,3}\.[0-9]{1,3}' \
  "内网 IP 地址 (172.16-31.x.x)" "WARN"

# =============================================================================
# 4. 沙箱 / OpenClaw 配置
# =============================================================================

check_pattern "OPENCLAW" \
  '(?i)(sandboxid|sandbox[_-]?id)\s*[:=]\s*["\x27]?[a-zA-Z0-9\-]{8,}' \
  "沙箱 sandboxId 泄露"

check_pattern "OPENCLAW" \
  'openclaw\.json' \
  "openclaw.json 配置文件引用（内容可能含 token）" "WARN"

check_pattern "OPENCLAW" \
  'device-auth\.json' \
  "device-auth.json 设备认证文件引用" "WARN"

check_pattern "OPENCLAW" \
  '(?i)botmisid\s*[:=]\s*["\x27]?[a-z0-9]{10,}' \
  "botMisId 泄露"

# =============================================================================
# 5. 私有规则（从 .git/hooks/private-rules.txt 加载）
# =============================================================================
if [ -f "$PRIVATE_RULES_FILE" ]; then
  while IFS='|' read -r category pattern description severity || [ -n "$category" ]; do
    [[ -z "$category" || "$category" == \#* ]] && continue
    severity="${severity:-ERROR}"
    check_pattern "$category" "$pattern" "$description" "$severity"
  done < "$PRIVATE_RULES_FILE"
fi

# =============================================================================
# 6. 文件类型检查（staged 文件本身）
# =============================================================================

check_file_pattern "PRIVKEY" \
  '\.(pem|key|p12|pfx|ppk|asc)$' \
  "私钥/证书文件"

check_file_pattern "CONFIG" \
  '(\.env$|\.env\..+|\.secret$|credentials|id_rsa|id_ecdsa|id_ed25519)' \
  "疑似敏感配置/凭证文件"

check_file_pattern "OPENCLAW" \
  '(openclaw\.json|device-auth\.json|paired\.json|device\.json)' \
  "OpenClaw 敏感配置文件"

check_file_pattern "PRIVATE_SCRIPT" \
  '(^|/)(gen-infographic(-.*)?\.py|insert-infographic\.py|\.friday-appid)$' \
  "私有脚本或本地 appid 文件"

check_file_pattern "DB" \
  '\.(sqlite|sqlite3|db)$' \
  "数据库文件（可能含用户数据）" "WARN"

check_file_pattern "LOG" \
  '\.log$' \
  "日志文件（可能含敏感信息）" "WARN"

# =============================================================================
# 7. 全量扫描额外检查（仅 SCAN_MODE=full 时执行）
# =============================================================================
if [ "$SCAN_MODE" = "full" ]; then
  if [ "$VERBOSE" = "1" ]; then
    echo -e "${CYAN}[安全检查] 执行全仓库扫描...${NC}"
  fi

  # 调用 Python 扫描脚本（如果存在）
  SCANNER="$REPO_ROOT/.githook/scanner.py"
  if [ -f "$SCANNER" ] && command -v python3 &>/dev/null; then
    if ! python3 "$SCANNER" --mode full --repo-root "$REPO_ROOT" 2>&1; then
      ERRORS+=("[SCANNER] Python 全量扫描发现问题，见上方输出")
      FAIL=1
    fi
  fi
fi

# =============================================================================
# 8. 结果输出
# =============================================================================

echo ""
echo "================================================"
echo "  🔒 Security Pre-commit Check  [$SCAN_MODE]"
echo "================================================"

if [ ${#ERRORS[@]} -gt 0 ]; then
  echo -e "${RED}❌ 发现以下安全问题（BLOCK — 提交被阻止）：${NC}"
  for err in "${ERRORS[@]}"; do
    echo -e "  ${RED}✗ $err${NC}"
  done
  echo ""
fi

if [ ${#WARNINGS[@]} -gt 0 ]; then
  echo -e "${YELLOW}⚠️  发现以下警告（请人工确认，本次不阻止提交）：${NC}"
  for warn in "${WARNINGS[@]}"; do
    echo -e "  ${YELLOW}! $warn${NC}"
  done
  echo ""
fi

if [ $FAIL -eq 0 ] && [ ${#WARNINGS[@]} -eq 0 ]; then
  echo -e "${GREEN}✅ 安全检查通过${NC}"
fi

if [ ${#ERRORS[@]} -gt 0 ] || [ ${#WARNINGS[@]} -gt 0 ]; then
  echo "------------------------------------------------"
fi

if [ $FAIL -eq 1 ]; then
  echo -e "${RED}提交已阻止。请清理敏感内容后重新提交。${NC}"
  echo ""
  echo "跳过此检查（慎用）: git commit --no-verify"
  echo "================================================"
  echo ""
  exit 1
fi

echo "================================================"
echo ""
exit 0
